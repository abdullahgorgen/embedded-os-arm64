# ===================================================================
# .gitignore - ARM64 Embedded Linux / C / Kernel Module Outputs
# ===================================================================

# Keep repository skeleton markers.
!**/.gitkeep

# C and userspace build outputs
*.o
*.a
*.d
*.su
source_code/collector
source_code/monitor
source_code/display
source_code/stress_mem

# Linux kernel module build outputs
*.ko
*.mod
*.mod.c
.*.cmd
.tmp_versions/
modules.order
Module.symvers
*.symvers

# Kernel, QEMU, RootFS and boot images
*.img
Image
vmlinux
qemu/Image
rootfs/*.img

# Device Tree generated artifacts
*.dtb
dts/*.dts

# Downloaded and extracted external sources
*.tar
*.tar.*
qemu/linux-*/
rootfs/busybox-*/
rootfs/busybox_install/

# RootFS staging tree generated during packaging
rootfs/rootfs_tree/

# Logs and temporary files
*.log
*.tmp
tmp/

# Editor, OS and language tooling artifacts
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
__pycache__/
*.pyc

# Local assignment/report scratch files
prompt.txt
report_sablonu.md
